# Codemate-Hub environment template
# Copy to .env and customize:  cp .env.example .env
# Do NOT commit real secrets. .env is gitignored.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Password for code-server (linuxserver/code-server)
PASSWORD=change-me-to-a-strong-password

# ---------------------------------------------------------------------------
# Core service URLs / paths (defaults match docker-compose.yml)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
CHROMA_DB_DIR=/app/chroma_db

# Optional: expose code-server on a different host port
CODE_SERVER_PORT=8443

# Optional: nginx publish ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_PORT=8888

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
# Change this in any shared/LAN deployment
WEBUI_SECRET_KEY=change-me-webui-secret

# ---------------------------------------------------------------------------
# Optional API keys (leave empty unless needed)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=
# BRAVE_API_KEY=
# DATABASE_URL=

# ---------------------------------------------------------------------------
# Observability (used when deploying docker-compose.observability.yml)
# ---------------------------------------------------------------------------
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me-grafana
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
